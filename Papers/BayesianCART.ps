/bb-fontheight {
	currentfont begin
	FontBBox
	exch pop 0 exch
	FontMatrix transform
	exch pop 3 1 roll
	exch pop 0 exch
	FontMatrix transform
	exch pop
	end
	dup /down exch def
	sub /height exch def
} def

/whiteout {
 gsave
  dup -2 div -2 rmoveto
  1 setgray
  currentpoint newpath moveto
  0 down rmoveto
  dup 0 rlineto
  0 height rlineto
  neg 0 rlineto
  closepath fill
 grestore
} def

