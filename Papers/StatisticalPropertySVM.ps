            }if
            CurByte MaskMove bitshift MaskByte and
            dup 0 gt{
                Sc
                exch dup 3 1 roll B M 1 z 1 w 1 y F
            }{pop pop}ifelse
            Left 1 sub dup /Left exch def 0 le
            {/Left PerByte def}
            {/MaskMove MaskMove Bits add def}ifelse
        }for
        pop
    }for
    /Colors GColors def saveSc Sc
