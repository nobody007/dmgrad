}bd
/BWOp{
    bw{currentrgbcolor add add 2.9 gt{1}{0}ifelse setgray}if
    exec
    bw{CurSc Sc}if
}bd
/IBu{}def
/B{newpath}bd
/E{{stroke}BWOp}bd
/C{currentpoint Penup{newpath}{E}ifelse moveto}bd
/F{closepath eofill}bd
